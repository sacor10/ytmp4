<Application x:Class="YtMp4.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:YtMp4.Converters"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVisible" TrueValue="Visible" FalseValue="Collapsed"/>
        <conv:BoolToVisibilityConverter x:Key="BoolToHidden" TrueValue="Collapsed" FalseValue="Visible"/>
        <conv:InvertBoolConverter x:Key="InvertBool"/>
    </Application.Resources>
</Application>
